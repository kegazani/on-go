{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://on-go/contracts/personalization/polar-first-feature-contract.schema.json",
  "title": "OnGo Polar-First Feature Contract",
  "description": "Canonical feature contract for activity/arousal/valence where Polar H10 is the only cardio source and Apple Watch is motion/context only.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contract_version",
    "source_policies",
    "tracks",
    "forbidden_watch_cardio"
  ],
  "properties": {
    "contract_version": {
      "type": "string",
      "const": "polar-first-feature-contract-v1"
    },
    "source_policies": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "polar_cardio_only",
        "watch_motion_only"
      ],
      "properties": {
        "polar_cardio_only": {
          "type": "boolean",
          "const": true,
          "description": "Cardio/autonomic features must be derived only from Polar H10 streams."
        },
        "watch_motion_only": {
          "type": "boolean",
          "const": true,
          "description": "Watch features are restricted to motion/context; watch heart-related features are not allowed in training/runtime contracts."
        }
      }
    },
    "tracks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "activity",
        "arousal_coarse",
        "valence_coarse"
      ],
      "properties": {
        "activity": {
          "$ref": "#/$defs/track_contract"
        },
        "arousal_coarse": {
          "$ref": "#/$defs/track_contract"
        },
        "valence_coarse": {
          "$ref": "#/$defs/track_contract"
        }
      }
    },
    "forbidden_watch_cardio": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "forbidden_streams",
        "forbidden_feature_prefixes"
      ],
      "properties": {
        "forbidden_streams": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "watch_heart_rate",
              "watch_hrv",
              "watch_bvp",
              "watch_eda",
              "watch_temp"
            ]
          },
          "uniqueItems": true
        },
        "forbidden_feature_prefixes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "watch_hr_",
              "watch_hrv_",
              "watch_bvp_",
              "watch_eda_",
              "watch_temp_"
            ]
          },
          "uniqueItems": true
        }
      }
    }
  },
  "$defs": {
    "track_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_streams",
        "optional_streams",
        "feature_families"
      ],
      "properties": {
        "required_streams": {
          "$ref": "#/$defs/stream_list"
        },
        "optional_streams": {
          "$ref": "#/$defs/stream_list"
        },
        "feature_families": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "must",
            "should",
            "could"
          ],
          "properties": {
            "must": {
              "$ref": "#/$defs/feature_family_list"
            },
            "should": {
              "$ref": "#/$defs/feature_family_list"
            },
            "could": {
              "$ref": "#/$defs/feature_family_list"
            }
          }
        }
      }
    },
    "stream_list": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "polar_hr",
          "polar_rr",
          "polar_ecg",
          "polar_acc",
          "watch_accelerometer",
          "watch_gyroscope",
          "watch_activity_context"
        ]
      },
      "uniqueItems": true
    },
    "feature_family_list": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "polar_rr_time_domain_hrv",
          "polar_rr_frequency_domain_hrv",
          "polar_rr_nonlinear_hrv",
          "polar_hr_level_variability",
          "polar_ecg_quality",
          "polar_acc_motion_quality",
          "watch_acc_kinematics",
          "watch_gyro_kinematics",
          "watch_activity_context_categorical",
          "quality_gate_flags",
          "subject_baseline_normalized_deltas",
          "respiration_proxy_from_rr"
        ]
      },
      "uniqueItems": true
    }
  }
}
