SPW_DATABASE_DSN=postgresql://on_go:on_go@localhost:5432/on_go

SPW_S3_ENDPOINT_URL=http://localhost:9000
SPW_S3_REGION=us-east-1
SPW_S3_RAW_BUCKET=on-go-raw
SPW_S3_CLEAN_BUCKET=on-go-raw
SPW_S3_ACCESS_KEY_ID=minioadmin
SPW_S3_SECRET_ACCESS_KEY=minioadmin
SPW_S3_FORCE_PATH_STYLE=true

SPW_CLEAN_ROOT_PREFIX=clean-sessions
SPW_PREPROCESSING_VERSION=e1-v1
SPW_GAP_FACTOR=1.8
SPW_MAX_SAMPLES_PER_STREAM=200000
SPW_PERSIST_OUTPUTS=true
