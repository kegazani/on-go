REPLAY_APP_HOST=0.0.0.0
REPLAY_APP_PORT=8090
REPLAY_APP_LOG_LEVEL=info

REPLAY_DATABASE_DSN=postgresql://on_go:on_go@localhost:5432/on_go

REPLAY_S3_ENDPOINT_URL=http://localhost:9000
REPLAY_S3_REGION=us-east-1
REPLAY_S3_BUCKET=on-go-raw
REPLAY_S3_ACCESS_KEY_ID=minioadmin
REPLAY_S3_SECRET_ACCESS_KEY=minioadmin
REPLAY_S3_FORCE_PATH_STYLE=true

REPLAY_DEFAULT_WINDOW_MS=5000
REPLAY_MAX_WINDOW_MS=600000
REPLAY_MAX_SAMPLES_PER_STREAM=2000
